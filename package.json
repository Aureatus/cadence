{
  "name": "cadence",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORTLESS_HTTPS=0 PORTLESS_PORT=1355 portless run --force astro dev",
    "build": "astro check && astro build",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --react-plugin --jsx-a11y-plugin --deny-warnings --ignore-path .gitignore .",
    "analyze": "ANALYZE=1 astro build",
    "deploy": "astro build && alchemy deploy",
    "deploy:destroy": "alchemy destroy",
    "pwa:assets": "pwa-assets-generator pwa-source.svg --preset minimal --root public --override --manifest false",
    "check:knip": "knip --no-progress",
    "check:jscpd": "jscpd . --config .jscpd.json",
    "check:fallow": "fallow --only dead-code,dupes --fail-on-issues",
    "check:fallow:health": "fallow --only health --summary || true",
    "check:fallow:full": "fallow --fail-on-issues",
    "check": "bun run format:check && bun run lint && bun run check:knip && bun run check:jscpd && bun run check:fallow && bun run check:fallow:health",
    "preview": "astro preview",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tanstack/svelte-db": "^0.1.82",
    "bits-ui": "^2.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-svelte": "^1.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/svelte": "^8.1.0",
    "@kindspells/astro-shield": "^1.7.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vite-pwa/astro": "^1.2.0",
    "alchemy": "^0.93.7",
    "astro": "^6.3.1",
    "fallow": "^2.64.0",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "portless": "^0.12.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte": "^5.55.5",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.2"
  },
  "packageManager": "bun@1.3.5",
  "portless": "cadence"
}
