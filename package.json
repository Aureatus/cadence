{
  "name": "cadence",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORTLESS_HTTPS=0 PORTLESS_PORT=1355 portless run vite",
    "build": "tsc -b && vite build",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --react-plugin --jsx-a11y-plugin --deny-warnings --ignore-path .gitignore .",
    "pwa:assets": "pwa-assets-generator pwa-source.svg --preset minimal --root public --override --manifest false",
    "check:knip": "knip --no-progress",
    "check:jscpd": "jscpd . --config .jscpd.json",
    "check:fallow": "fallow --only dead-code,dupes --fail-on-issues",
    "check:fallow:health": "fallow --only health --summary || true",
    "check:fallow:full": "fallow --fail-on-issues",
    "check": "bun run format:check && bun run lint && bun run check:knip && bun run check:jscpd && bun run check:fallow && bun run check:fallow:health",
    "preview": "vite preview",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/dm-sans": "^5.2.8",
    "@tanstack/react-db": "^0.1.83",
    "@tanstack/react-router": "^1.169.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^5.2.0",
    "fallow": "^2.64.0",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "portless": "^0.12.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0"
  },
  "packageManager": "bun@1.3.5",
  "portless": "cadence"
}
