{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schemas/config.schema.json",
  "entry": ["astro.config.mjs", "svelte.config.js", "playwright.config.ts"],
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "dev-dist/**",
    "playwright-report/**",
    "test-results/**",
    "public/**"
  ],
  "duplicates": {
    "threshold": 80,
    "minLines": 8
  }
}
